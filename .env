
ENCRYPTION_KEY=febe69f5888ca2472ce75b0b8928afa0d80d82be25d88e20b15a832834499ae9

# local | central
APP_MODE=local

# Identifiant unique de l'instance locale
SYNC_INSTANCE_ID=poste-01

# URL du serveur central (optionnelle si l'adresse est saisie manuellement lors de la synchronisation)
SYNC_CENTRAL_URL=

# Jeton partagé entre instances locales et serveur central
SYNC_SHARED_TOKEN=CHANGE_ME_SYNC_TOKEN

# Timeout HTTP (secondes)
SYNC_TIMEOUT=30

# Exiger HTTPS lors de la réception côté central
SYNC_REQUIRE_HTTPS=true

# --- Connexion directe à la base centrale distante (si utilisée) ---
CENTRAL_DB_HOST=IP_DU_SERVEUR_MYSQL_CENTRAL
CENTRAL_DB_PORT=3306
CENTRAL_DB_NAME=ctr.net-fardc-active-web-1
CENTRAL_DB_USER=root
CENTRAL_DB_PASS=